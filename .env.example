# Copy this file to .env and update the values for Forge commands.

# Your Atlassian site URL.
# e.g. if your site is mycompany.atlassian.net, set FORGE_SITE=mycompany.atlassian.net
FORGE_SITE=example.atlassian.net

# The Atlassian product to install the app on.
# This app is a Jira Automation action, so this must be jira.
FORGE_PRODUCT=jira

# The Forge environment targeted by Forge CLI scripts.
# Common values: development, staging, production
FORGE_ENVIRONMENT=development

# Source Config: a JSON object describing the org, directory, Authorized
# Initiator emails, and Allowed Groups. See
# docs/admin-access-automation-spec.md for the schema, and README.md for
# how to find orgId/directoryId.
# Uploaded as a PLAIN (not encrypted) Forge variable.
ADMIN_ASSIGNMENT_SOURCE_CONFIG_JSON={"orgId":"your-org-id","directoryId":"your-dire
ctory-id","authorizedInitiatorEmails":["you@example.com"],"allowedGroups":[{"key":"
jira-admins","label":"Jira admins","name":"jira-administrators"}]}

# Service Credential: an org admin API key used to call the Organizations
# REST API. See the link in README.md's Configuration section for how to
# create one.
# Uploaded as an ENCRYPTED Forge variable (its name matches *TOKEN* in
# scripts/forge-vars-from-env.sh).
ADMIN_ASSIGNMENT_API_TOKEN=your-org-admin-api-token
